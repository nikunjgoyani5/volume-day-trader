PORT=5000
CLIENT_URL=http://localhost:3000
ADMIN_CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/volumedaytrader

JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=
# dall-e-3 is deprecated; use gpt-image-1 (default) or gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-1

# Cloudinary — required for all blog cover images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_StrongPassword123

# Brevo — REQUIRED for contact form emails (see server/docs/BREVO_SETUP.md)
# Option A: verified sender + API key
# BREVO_SENDER_EMAIL=your-verified@email.com
# BREVO_SMTP_KEY=xkeysib-paste-real-key-from-brevo-dashboard
# Option B: SMTP (email | xsmtpsib key)
# BREVO_SMTP_KEY=your-brevo-login@email.com|xsmtpsib-your-smtp-key-here
BREVO_SMTP_KEY=

# Contact form — yopmail OK as recipient
INQUIRY_NOTIFY_EMAIL=volumedaytrader@yopmail.com

# Required for reliable yopmail delivery (Google App Password, 16 chars)
GMAIL_USER=your-verified@gmail.com
GMAIL_APP_PASSWORD=your-google-app-password
EMAIL_USE_GMAIL_FOR_DISPOSABLE=true
